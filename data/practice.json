          "title": "Two Sum",
          "description": "Дан массив nums и target. Вернуть индексы двух чисел, сумма которых равна target.",
          "approach": "Один проход + HashMap: для каждого элемента ищем complement = target - nums[i].",
          "pattern": "HashMap",
          "leetcodeUrl": "https://leetcode.com/problems/two-sum/",
          "leetcodeLabel": "1. Two Sum",
          "complexity": "O(n)",
          "algorithm": "CLRS §11.4; complement + HashMap",
          "code": "public int[] twoSum(int[] nums, int target) {\n    Map<Integer, Integer> map = new HashMap<>();\n    for (int i = 0; i < nums.length; i++) {\n        int complement = target - nums[i];\n        if (map.containsKey(complement))\n            return new int[]{map.get(complement), i};\n        map.put(nums[i], i);\n    }\n    throw new IllegalArgumentException(\"No solution\");\n}",
          "searchText": "Two Sum Дан массив nums и target. Вернуть индексы двух чисел, сумма которых равна target. HashMap и частоты практика"
