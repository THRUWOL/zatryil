    {
      "id": "p6",
      "num": 6,
      "type": "interview",
      "category": "hashmap",
      "categoryTitle": "HashMap и частоты",
      "title": "Найти дубликаты в List",
      "description": "Задача: Найти дубликаты в List",
      "approach": "HashSet; `Set.add()` → false",
      "pattern": "HashMap и частоты",
      "leetcodeUrl": null,
      "leetcodeLabel": null,
      "complexity": "O(n)",
      "algorithm": "HashSet; `Set.add()` → false",
      "code": "public int lengthOfLongest(String s) {\n    Map<Character, Integer> lastSeen = new HashMap<>();\n    int maxLen = 0, start = 0;\n    for (int i = 0; i < s.length(); i++) {\n        char c = s.charAt(i);\n        if (lastSeen.containsKey(c) && lastSeen.get(c) >= start)\n            start = lastSeen.get(c) + 1;\n        lastSeen.put(c, i);\n        maxLen = Math.max(maxLen, i - start + 1);\n    }\n    return maxLen;\n}",
      "searchText": "Найти дубликаты в List  HashMap и частоты практика"
    },
    {
      "id": "p7",
